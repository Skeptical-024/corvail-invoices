# Required: Gemini API key
GEMINI_API_KEY=your_gemini_api_key

# Optional: Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Required: API key for inbound requests
API_SECRET=change_me

# Optional: ERP webhook URL for invoice payload delivery
ERP_WEBHOOK_URL=https://erp.example.com/webhooks/invoices

# Optional: max upload size in bytes (default 20MB)
MAX_UPLOAD_BYTES=20971520

# Optional: allow SendGrid inbound without auth
SENDGRID_INBOUND_OPEN=false

# Optional: Slack webhook URL for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Optional: SendGrid API key for alert emails
SENDGRID_API_KEY=sendgrid_api_key

# Optional: alert sender email address
ALERT_EMAIL_FROM=alerts@corvail.one

# Optional: alert recipient email address
ALERT_EMAIL_TO=ops@corvail.one

# Optional: environment label
ENVIRONMENT=production

# Optional: log level
LOG_LEVEL=INFO
